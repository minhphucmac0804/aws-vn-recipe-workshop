## For src/lambda-e5-rag/handler.py
## This is the bundled-E5 Lambda RAG path.
QUERY_LOG_TABLE=
RECIPE_BUCKET=
RECIPE_KEY=data/sample_recipes.json
RETRIEVAL_METHOD=keyword_s3
TOP_K=5

WORKSHOP_QDRANT_URL=
WORKSHOP_QDRANT_API_KEY=
WORKSHOP_QDRANT_COLLECTION=
WORKSHOP_QDRANT_TOP_K=5

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TEMPERATURE=0.2
GEMINI_TIMEOUT_SECONDS=20

LAMBDA_RAG_ENABLED=true
QDRANT_TIMEOUT_SECONDS=20
QDRANT_RETRIEVAL_METHOD=qdrant_dense

WORKSHOP_EMBEDDER_MODEL=intfloat/multilingual-e5-base
WORKSHOP_EMBEDDER_MODEL_HF=intfloat/multilingual-e5-base
WORKSHOP_EMBEDDER_MODEL_FILE=model_qint8_avx512_vnni.onnx
WORKSHOP_EMBEDDER_MODEL_PATH=/var/task/models/multilingual-e5-base/onnx
WORKSHOP_EMBEDDER_POOLING=MEAN
WORKSHOP_EMBEDDER_NORMALIZATION=true
WORKSHOP_EMBEDDER_VECTOR_SIZE=768
